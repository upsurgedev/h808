      "@type": "LocalBusiness",
      "name": "Hawaii Painters 808",
      "description": "Licensed, insured painting contractor serving Oahu.",
      "url": "https://housepaintershonolulu.com",
      "telephone": "808-272-3816",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Honolulu",
        "addressRegion": "HI",
        "postalCode": "96813",
        "addressCountry": "US"
      },
      "openingHours": "Mo-Sa 07:00-18:00",

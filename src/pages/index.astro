---
import HomePage from "../react-pages/home/page.tsx";
import "../styles/global.css";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hawaii Painters 808 | Oahu Painting Contractor | Free Estimates</title>
    <meta name="description" content="Hawaii Painters 808 — Oahu's trusted painting contractor since 2012. Interior, exterior, cabinet painting & drywall repair. Licensed, insured. Lopaka personally oversees every job. Call 808-272-3816 for a free estimate." />
    <meta name="keywords" content="painting contractor Oahu Hawaii, painters Oahu, house painting Hawaii, Hawaii Painters 808, Honolulu painting contractor, exterior painting Oahu, interior painting Hawaii" />
    <meta name="geo.region" content="US-HI" />
    <meta name="geo.placename" content="Honolulu, Hawaii" />
    <link rel="canonical" href="https://housepaintershonolulu.com/" />
    <meta property="og:title" content="Hawaii Painters 808 | Oahu's Trusted Painting Contractor" />
    <meta property="og:description" content="Licensed, insured painting contractor serving all of Oahu since 2012. Interior, exterior, cabinet painting & drywall. Free estimates. Call 808-272-3816." />

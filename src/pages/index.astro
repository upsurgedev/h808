<script>
  (function() {
    const navbar = document.getElementById('hp808-navbar');

    // ── Scroll behavior ──
    window.addEventListener('scroll', function() {
      if (window.scrollY > 60) {
        navbar.classList.add('scrolled');
      } else {
        navbar.classList.remove('scrolled');
      }
    });

    // ── Desktop dropdowns ──
    const servicesBtn = document.getElementById('services-btn');
    const servicesMenu = document.getElementById('services-menu');
    const areasBtn = document.getElementById('areas-btn');
    const areasMenu = document.getElementById('areas-menu');
    const servicesDropdown = document.getElementById('services-dropdown');
    const areasDropdown = document.getElementById('areas-dropdown');

    function openServices() {
      servicesMenu.classList.add('open');
      servicesBtn.classList.add('open');
      servicesBtn.setAttribute('aria-expanded', 'true');
      areasMenu.classList.remove('open');
      areasBtn.classList.remove('open');
    }

    function closeServices() {
      servicesMenu.classList.remove('open');
      servicesBtn.classList.remove('open');
      servicesBtn.setAttribute('aria-expanded', 'false');
    }

    function openAreas() {
      areasMenu.classList.add('open');
      areasBtn.classList.add('open');
      areasBtn.setAttribute('aria-expanded', 'true');
      servicesMenu.classList.remove('open');
      servicesBtn.classList.remove('open');
    }

    function closeAreas() {
      areasMenu.classList.remove('open');
      areasBtn.classList.remove('open');
      areasBtn.setAttribute('aria-expanded', 'false');
    }

    // Hover
    servicesDropdown.addEventListener('mouseenter', openServices);
    servicesDropdown.addEventListener('mouseleave', closeServices);
    areasDropdown.addEventListener('mouseenter', openAreas);
    areasDropdown.addEventListener('mouseleave', closeAreas);

    // Click (for touch devices)
    servicesBtn.addEventListener('click', function(e) {
      e.stopPropagation();
      if (servicesMenu.classList.contains('open')) {
        closeServices();
      } else {
        openServices();
      }
    });

    areasBtn.addEventListener('click', function(e) {
      e.stopPropagation();
      if (areasMenu.classList.contains('open')) {
        closeAreas();
      } else {
        openAreas();
      }
    });

    // Click outside to close
    document.addEventListener('click', function() {
      closeServices();
      closeAreas();
    });

    // ── Mobile menu ──
    const hamburger = document.getElementById('hp808-hamburger');
    const hamburgerIcon = document.getElementById('hp808-hamburger-icon');
    const mobileMenu = document.getElementById('hp808-mobile-menu');

    hamburger.addEventListener('click', function() {
      const isOpen = mobileMenu.classList.toggle('open');
      hamburgerIcon.className = isOpen ? 'ri-close-line' : 'ri-menu-line';
    });

    // Mobile accordions
    const mobileServicesBtn = document.getElementById('mobile-services-btn');
    const mobileServicesMenu = document.getElementById('mobile-services-menu');
    const mobileAreasBtn = document.getElementById('mobile-areas-btn');
    const mobileAreasMenu = document.getElementById('mobile-areas-menu');

    mobileServicesBtn.addEventListener('click', function() {
      const isOpen = mobileServicesMenu.classList.toggle('open');
      mobileServicesBtn.classList.toggle('open', isOpen);
    });

    mobileAreasBtn.addEventListener('click', function() {
      const isOpen = mobileAreasMenu.classList.toggle('open');
      mobileAreasBtn.classList.toggle('open', isOpen);
    });
  })();
</script>


    display: flex;
    align-items: center;
    gap: 4px;
    color: white;
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    background: none;
    border: none;
    cursor: pointer;
    white-space: nowrap;
    transition: color 0.2s;
    font-family: inherit;
    padding: 0;
  }

  .hp808-dropdown-btn:hover { color: #4a9fa5; }

  .hp808-dropdown-btn i {
    font-size: 1rem;
    transition: transform 0.2s;
  }

  .hp808-dropdown-btn.open i { transform: rotate(180deg); }

  /* ── DROPDOWN MENU ── */
  .hp808-dropdown-menu {
    display: none;
    position: absolute;
    top: 100%; padding-top: 0.75rem;
    left: 50%;
    transform: translateX(-50%);

  .hp808-dropdown-menu.services-menu { width: 16rem; }
  .hp808-dropdown-menu.areas-menu { width: 28rem; }
  .hp808-dropdown-menu.open { display: block; }

  /* Invisible bridge fills the gap so mouseleave never fires mid-hover */
  .hp808-dropdown::before {
    content: '';
    position: absolute;
    top: 100%;
    left: -1rem;
    right: -1rem;
    height: 0.75rem;
    background: transparent;
  }

  .hp808-dropdown-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    color: rgba(255,255,255,0.6);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    transition: color 0.2s, background 0.2s;
    text-decoration: none;
    display: flex;
  }

  .hp808-dropdown-header:hover {
    color: #4a9fa5;
    background: rgba(255,255,255,0.05);
  }

  .hp808-dropdown-item {
    display: flex;

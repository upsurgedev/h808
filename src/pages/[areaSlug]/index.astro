    desc: "Professional painting contractor in Kapolei, Hawaii. Interior, exterior, cabinet painting. Licensed, insured. Free estimates. Call 808-272-3816.",
  },
  "painters-ewa-beach-hi": {
    title: "Painters in Ewa Beach HI | Hawaii Painters 808 | Free Estimates",
    desc: "Professional painting contractor in Ewa Beach, Hawaii. Interior, exterior, cabinet painting. Licensed, insured. Free estimates. Call 808-272-3816.",
  },
  "painters-north-shore-hi": {
    title: "Painters on the North Shore HI | Hawaii Painters 808",

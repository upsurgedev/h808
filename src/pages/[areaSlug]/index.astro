import "../../styles/global.css";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{meta.title}</title>
    <meta name="description" content={meta.desc} />
    <link rel="canonical" href={`https://housepaintershonolulu.com/${areaSlug}`} />
    <meta property="og:title" content={meta.title} />
    <meta property="og:description" content={meta.desc} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://housepaintershonolulu.com/${areaSlug}`} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/remixicon@4.5.0/fonts/remixicon.css" />
  </head>
  <body>
    {areaSlug === "painters-honolulu-hi" && <PaintersHonoluluPage client:load />}
    {areaSlug === "painters-hawaii-kai-hi" && <PaintersHawaiiKaiPage client:load />}
    {areaSlug === "painters-kahala-diamond-head-hi" && <PaintersKahalaPage client:load />}

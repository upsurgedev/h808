export function getStaticPaths() {
  return [
    { params: { areaSlug: "painters-honolulu-hi" } },
    { params: { areaSlug: "painters-hawaii-kai-hi" } },
    { params: { areaSlug: "painters-kahala-diamond-head-hi" } },
    { params: { areaSlug: "painters-kailua-hi" } },
    { params: { areaSlug: "painters-kaneohe-hi" } },
    { params: { areaSlug: "painters-pearl-city-hi" } },

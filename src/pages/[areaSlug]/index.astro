    { params: { areaSlug: "painters-ewa-beach-hi" } },
    { params: { areaSlug: "painters-north-shore-hi" } },
    { params: { areaSlug: "painters-mililani-hi" } },
    { params: { areaSlug: "painters-waipahu-hi" } },
  ];
}

const { areaSlug } = Astro.params;

const areaMeta: Record<string, { title: string; desc: string }> = {
